generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================================
// MASTER DATA
// ================================

model Specialty {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  basePrice   Decimal   @map("base_price")
  description String?
  doctors     Doctor[]
  diseases    Disease[]

  @@map("specialties")
}

model DiseaseCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  diseases    Disease[]

  @@map("disease_categories")
}

// ================================
// USERS
// ================================

model Profile {
  id        String    @id @default(uuid()) @db.Uuid
  fullName  String    @map("full_name")
  email     String?   @unique
  phone     String    @unique
  avatarUrl String?   @map("avatar_url")
  role      String? // 'admin', 'doctor', 'patient'
  dob       DateTime? @db.Date
  address   String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  isActive  Boolean   @default(true) @map("is_active")

  // Relations
  doctor                Doctor?
  appointmentsAsPatient Appointment[]  @relation("PatientAppointments")
  appointmentsAsDoctor  Appointment[]  @relation("DoctorAppointments")
  schedulesAsDoctor     Schedule[]     @relation("DoctorSchedules") // <-- ĐÃ THÊM QUAN HỆ ẢO TỚI BẢNG SCHEDULE
  notifications         Notification[]
  chatSessions          ChatSession[]

  @@map("profiles")
}

// ================================
// DOCTORS
// ================================

model Doctor {
  id           String  @id @db.Uuid
  specialtyId  String? @map("specialty_id") @db.Uuid
  degree       String?
  experience   String?
  education    String?
  achievements String?

  profile   Profile    @relation(fields: [id], references: [id], onDelete: Cascade)
  specialty Specialty? @relation(fields: [specialtyId], references: [id])

  @@index([specialtyId], name: "idx_doctor_specialty")
  @@map("doctors")
}

// ================================
// MEDICAL KNOWLEDGE
// ================================

model Disease {
  id          String  @id @default(uuid()) @db.Uuid
  categoryId  String? @map("category_id") @db.Uuid
  specialtyId String? @map("specialty_id") @db.Uuid
  name        String

  nameClean String? @map("name_clean")

  imageUrl      String? @map("image_url")
  description   String?
  symptoms      String
  homeTreatment String? @map("home_treatment")

  embedding Unsupported("vector(1536)")?

  category  DiseaseCategory?  @relation(fields: [categoryId], references: [id])
  specialty Specialty?        @relation(fields: [specialtyId], references: [id])
  medicines DiseaseMedicine[]

  @@index([nameClean(ops: raw("gin_trgm_ops"))], type: Gin, name: "idx_disease_name_clean_trgm")
  @@index([specialtyId], name: "idx_disease_specialty")
  @@index([categoryId], name: "idx_disease_category")
  @@map("diseases")
}

model Medicine {
  id               String            @id @default(uuid()) @db.Uuid
  name             String
  imageUrl         String?           @map("image_url")
  medicineType     String?           @map("medicine_type") // 'uống','ngậm','bôi','tiêm'
  ingredients      String?
  dosage           String?
  usageInstruction String?           @map("usage_instruction")
  sideEffects      String?           @map("side_effects")
  diseases         DiseaseMedicine[]

  @@map("medicines")
}

model DiseaseMedicine {
  diseaseId  String @map("disease_id") @db.Uuid
  medicineId String @map("medicine_id") @db.Uuid

  disease  Disease  @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  medicine Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@id([diseaseId, medicineId])
  @@map("disease_medicine")
}

// ================================
// SCHEDULES (THÊM MỚI BẢNG NÀY)
// ================================

model Schedule {
  id       String   @id @default(uuid()) @db.Uuid
  doctorId String   @map("doctor_id") @db.Uuid
  date     DateTime @db.Date
  shift    Int // Ca khám: 1, 2, 3, 4
  isBooked Boolean  @default(false) @map("is_booked")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  doctor      Profile      @relation("DoctorSchedules", fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment?

  @@unique([doctorId, date, shift])
  @@index([doctorId, date])
  @@map("schedules")
}

// ================================
// APPOINTMENTS & MEDICAL RECORDS
// ================================

model Appointment {
  id         String @id @default(uuid()) @db.Uuid
  patientId  String @map("patient_id") @db.Uuid
  doctorId   String @map("doctor_id") @db.Uuid
  scheduleId String @unique @map("schedule_id") @db.Uuid // <-- THAY THẾ DATE/SHIFT BẰNG SCHEDULE_ID

  status String  @default("pending") // 'pending', 'confirmed', 'completed', 'cancelled'
  reason String? @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  patient  Profile? @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor   Profile? @relation("DoctorAppointments", fields: [doctorId], references: [id])
  schedule Schedule @relation(fields: [scheduleId], references: [id]) // <-- LIÊN KẾT ĐẾN SCHEDULE

  notifications Notification[]
  medicalRecord MedicalRecord?

  @@index([patientId], name: "idx_appointment_patient")
  @@index([doctorId], name: "idx_appointment_doctor")
  @@map("appointments")
}

model MedicalRecord {
  id            String  @id @default(uuid()) @db.Uuid
  appointmentId String  @unique @map("appointment_id") @db.Uuid
  diagnosis     String  @db.Text
  prescription  String? @db.Text
  note          String? @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("medical_records")
}

// ================================
// NOTIFICATIONS
// ================================

model Notification {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  appointmentId String?  @map("appointment_id") @db.Uuid
  title         String?
  message       String?
  isRead        Boolean  @default(false) @map("is_read")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  user        Profile?     @relation(fields: [userId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([userId], name: "idx_notification_user")
  @@map("notifications")
}

// ================================
// NEWS
// ================================

model News {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  content   String
  newUrl    String?  @map("new_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("news")
}

// ================================
// AI CHAT SYSTEM
// ================================
// Khai báo Enum để phân biệt ai đang nói
enum MessageRole {
  USER // Bệnh nhân
  AI // Trợ lý MediCare
  SYSTEM // Prompt ẩn gài vào hệ thống (Không hiện lên UI)
}

model ChatSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  title     String?   @db.VarChar(255)
  topic     String?   @db.VarChar(100) // VD: "Tim mạch", "Tiêu hóa", "Da liễu"
  startedAt DateTime  @default(now()) @map("started_at") @db.Timestamptz
  endedAt   DateTime? @map("ended_at") @db.Timestamptz
  isActive  Boolean   @default(true) @map("is_active")

  user     Profile?      @relation(fields: [userId], references: [id])
  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid()) @db.Uuid
  sessionId String      @map("session_id") @db.Uuid
  role      MessageRole
  content   String      @db.Text
  metadata  Json?
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

// ================================
// USER EVENTS
// ================================

enum EventType {
  VIEW_DOCTOR
  BOOK_APPOINTMENT
  CANCEL_APPOINTMENT
  VIEW_DISEASE
  CHAT_AI_TOPIC
}

model UserEvent {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  eventType EventType @map("event_type")
  entityId  String?   @map("entity_id") @db.Uuid
  metadata  Json?     @default("{}")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventType])
  @@index([createdAt])
  @@index([entityId])
  @@map("user_events")
}

// ================================
// ETL REPORTS
// ================================

enum ReportName {
  raw_events
  top_doctors
  top_diseases
  peak_hours
  daily_summary
  chat_topics
}

model EtlReports {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mode        String     @db.VarChar(50)
  reportName  ReportName @map("report_name")
  startDate   DateTime   @map("start_date") @db.Date
  endDate     DateTime   @map("end_date") @db.Date
  totalEvents Int?       @default(0) @map("total_events")
  reports     Json?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([reportName, startDate])
  @@map("etl_reports")
}
