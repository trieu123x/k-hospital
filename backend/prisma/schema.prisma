generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Specialty {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  basePrice   Decimal   @map("base_price")
  description String?
  diseases    Disease[]
  doctors     Doctor[]

  @@map("specialties")
}

model DiseaseCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  diseases    Disease[]

  @@map("disease_categories")
}

model Profile {
  id                    String         @id @default(uuid()) @db.Uuid
  fullName              String         @map("full_name")
  email                 String?        @unique
  phone                 String         @unique
  avatarUrl             String?        @map("avatar_url")
  role                  String?
  dob                   DateTime?      @db.Date
  address               String?
  status                String?
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  appointmentsAsDoctor  Appointment[]  @relation("DoctorAppointments")
  appointmentsAsPatient Appointment[]  @relation("PatientAppointments")
  chatSessions          ChatSession[]
  doctor                Doctor?
  notifications         Notification[]

  @@map("profiles")
}

model Doctor {
  id           String     @id @db.Uuid
  specialtyId  String?    @map("specialty_id") @db.Uuid
  degree       String?
  experience   String?
  education    String?
  achievements String?
  profile      Profile    @relation(fields: [id], references: [id], onDelete: Cascade)
  specialty    Specialty? @relation(fields: [specialtyId], references: [id])

  @@index([specialtyId], map: "idx_doctor_specialty")
  @@map("doctors")
}

model Disease {
  id            String                 @id @default(uuid()) @db.Uuid
  categoryId    String?                @map("category_id") @db.Uuid
  specialtyId   String?                @map("specialty_id") @db.Uuid
  name          String
  imageUrl      String?                @map("image_url")
  description   String?
  symptoms      String
  homeTreatment String?                @map("home_treatment")
  embedding     Unsupported("vector")?
  nameClean     String?                @map("name_clean")
  medicines     DiseaseMedicine[]
  category      DiseaseCategory?       @relation(fields: [categoryId], references: [id])
  specialty     Specialty?             @relation(fields: [specialtyId], references: [id])

  @@index([nameClean(ops: raw("gin_trgm_ops"))], map: "idx_disease_name_clean_trgm", type: Gin)
  @@index([specialtyId], map: "idx_disease_specialty")
  @@index([categoryId], map: "idx_disease_category")
  @@map("diseases")
}

model Medicine {
  id               String            @id @default(uuid()) @db.Uuid
  name             String
  imageUrl         String?           @map("image_url")
  medicineType     String?           @map("medicine_type")
  ingredients      String?
  dosage           String?
  usageInstruction String?           @map("usage_instruction")
  sideEffects      String?           @map("side_effects")
  diseases         DiseaseMedicine[]

  @@map("medicines")
}

model DiseaseMedicine {
  diseaseId  String   @map("disease_id") @db.Uuid
  medicineId String   @map("medicine_id") @db.Uuid
  disease    Disease  @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  medicine   Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@id([diseaseId, medicineId])
  @@map("disease_medicine")
}

model Appointment {
  id            String         @id @default(uuid()) @db.Uuid
  patientId     String         @map("patient_id") @db.Uuid
  doctorId      String         @map("doctor_id") @db.Uuid
  status        String         @default("pending")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  date          DateTime       @db.Date
  reason        String?
  shift         Int
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  doctor        Profile        @relation("DoctorAppointments", fields: [doctorId], references: [id])
  patient       Profile        @relation("PatientAppointments", fields: [patientId], references: [id])
  medicalRecord MedicalRecord?
  notifications Notification[]

  @@index([patientId], map: "idx_appointment_patient")
  @@index([doctorId], map: "idx_appointment_doctor")
  @@map("appointments")
}

model MedicalRecord {
  id            String      @id @default(uuid()) @db.Uuid
  appointmentId String      @unique @map("appointment_id") @db.Uuid
  diagnosis     String
  prescription  String?
  note          String?
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("medical_records")
}

model Notification {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String?      @map("user_id") @db.Uuid
  appointmentId String?      @map("appointment_id") @db.Uuid
  title         String?
  message       String?
  isRead        Boolean      @default(false) @map("is_read")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  user          Profile?     @relation(fields: [userId], references: [id])

  @@index([userId], map: "idx_notification_user")
  @@map("notifications")
}

model News {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  content   String
  newUrl    String?  @map("new_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("news")
}

model ChatSession {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String?       @map("user_id") @db.Uuid
  startedAt DateTime      @default(now()) @map("started_at") @db.Timestamptz(6)
  isActive  Boolean       @default(true) @map("is_active")
  endedAt   DateTime?     @map("ended_at") @db.Timestamptz(6)
  title     String?       @db.VarChar(255)
  topic     String?       @db.VarChar(100)
  messages  ChatMessage[]
  user      Profile?      @relation(fields: [userId], references: [id])

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid()) @db.Uuid
  sessionId String      @map("session_id") @db.Uuid
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  content   String
  metadata  Json?
  role      MessageRole
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model UserEvent {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  eventType EventType @map("event_type")
  entityId  String?   @map("entity_id") @db.Uuid
  metadata  Json?     @default("{}")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventType])
  @@index([createdAt])
  @@index([entityId])
  @@map("user_events")
}

model EtlReports {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mode        String     @db.VarChar(50)
  reportName  ReportName @map("report_name")
  startDate   DateTime   @map("start_date") @db.Date
  endDate     DateTime   @map("end_date") @db.Date
  totalEvents Int?       @default(0) @map("total_events")
  reports     Json?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([reportName, startDate])
  @@map("etl_reports")
}

enum MessageRole {
  USER
  AI
  SYSTEM
}

enum EventType {
  VIEW_DOCTOR
  BOOK_APPOINTMENT
  CANCEL_APPOINTMENT
  VIEW_DISEASE
  CHAT_AI_TOPIC
}

enum ReportName {
  raw_events
  top_doctors
  top_diseases
  peak_hours
  daily_summary
  chat_topics
}
