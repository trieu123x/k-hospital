generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================================
// MASTER DATA
// ================================

model Specialty {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  basePrice   Decimal   @map("base_price")
  description String?
  doctors     Doctor[]
  diseases    Disease[]

  @@map("specialties")
}

model DiseaseCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  diseases    Disease[]

  @@map("disease_categories")
}

model Degree {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique // VD: Giáo sư, Tiến sĩ, CKI...
  description String?
  rankWeight  Int?     @map("rank_weight") // Dùng để sắp xếp thứ bậc (VD: GS = 100, TS = 90)
  doctors     Doctor[]

  @@map("degrees")
}

// Bảng mới: Lưu trữ danh mục loại thuốc
model MedicineType {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @unique // VD: Thuốc uống, Thuốc bôi...
  description String?
  medicines   Medicine[]

  @@map("medicine_types")
}

// ================================
// USERS
// ================================

enum UserRole {
  ADMIN
  DOCTOR
  PATIENT
}

model Profile {
  id             String    @id @default(uuid()) @db.Uuid
  fullName       String    @map("full_name")
  email          String?   @unique
  phone          String    @unique
  avatarUrl      String?   @map("avatar_url")
  avatarCropData Json?     @map("avatar_crop_data") // Lưu metadata cắt ảnh (x, y, width, height)
  role           UserRole? // Ràng buộc bằng Enum
  dob            DateTime? @db.Date
  address        String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  isActive       Boolean   @default(true) @map("is_active")

  // Relations
  doctor                Doctor?
  appointmentsAsPatient Appointment[]  @relation("PatientAppointments")
  appointmentsAsDoctor  Appointment[]  @relation("DoctorAppointments")
  doctorLeaves          DoctorLeave[]  @relation("DoctorLeaves")
  notifications         Notification[]
  chatSessions          ChatSession[]

  @@map("profiles")
}

// ================================
// DOCTORS
// ================================

model Doctor {
  id           String  @id @db.Uuid
  specialtyId  String? @map("specialty_id") @db.Uuid
  degreeId     String? @map("degree_id") @db.Uuid // Khóa ngoại trỏ sang bảng Degree
  experience   String?
  education    String?
  achievements String?

  profile   Profile    @relation(fields: [id], references: [id], onDelete: Cascade)
  specialty Specialty? @relation(fields: [specialtyId], references: [id])
  degree    Degree?    @relation(fields: [degreeId], references: [id])
  chunks    DoctorChunk[]

  @@index([specialtyId], name: "idx_doctor_specialty")
  @@index([degreeId], name: "idx_doctor_degree")
  @@map("doctors")
}

model DoctorChunk {
  id        String  @id @default(uuid()) @db.Uuid
  doctorId  String  @map("doctor_id") @db.Uuid
  content   String  @db.Text
  embedding Unsupported("vector(768)")?

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("doctor_chunks")
}

// ================================
// MEDICAL KNOWLEDGE
// ================================

model Disease {
  id          String  @id @default(uuid()) @db.Uuid
  categoryId  String? @map("category_id") @db.Uuid
  specialtyId String? @map("specialty_id") @db.Uuid
  name        String

  nameClean String? @map("name_clean")

  imageUrl      String? @map("image_url")
  description   String?
  symptoms      String
  homeTreatment String? @map("home_treatment")

  embedding Unsupported("vector(1536)")?

  category  DiseaseCategory?  @relation(fields: [categoryId], references: [id])
  specialty Specialty?        @relation(fields: [specialtyId], references: [id])
  medicines DiseaseMedicine[]
  chunks    DiseaseChunk[]

  @@index([nameClean(ops: raw("gin_trgm_ops"))], type: Gin, name: "idx_disease_name_clean_trgm")
  @@index([specialtyId], name: "idx_disease_specialty")
  @@index([categoryId], name: "idx_disease_category")
  @@map("diseases")
}

model DiseaseChunk {
  id        String  @id @default(uuid()) @db.Uuid
  diseaseId String  @map("disease_id") @db.Uuid
  content   String  @db.Text
  embedding Unsupported("vector(768)")?

  disease Disease @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@map("disease_chunks")
}

model Medicine {
  id               String  @id @default(uuid()) @db.Uuid
  name             String
  imageUrl         String? @map("image_url")
  typeId           String? @map("type_id") @db.Uuid // Khóa ngoại trỏ sang bảng MedicineType
  ingredients      String?
  dosage           String?
  usageInstruction String? @map("usage_instruction")
  sideEffects      String? @map("side_effects")

  medicineType MedicineType?     @relation(fields: [typeId], references: [id])
  diseases     DiseaseMedicine[]
  chunks       MedicineChunk[]

  @@index([typeId], name: "idx_medicine_type")
  @@map("medicines")
}

model MedicineChunk {
  id         String  @id @default(uuid()) @db.Uuid
  medicineId String  @map("medicine_id") @db.Uuid
  content    String  @db.Text
  embedding  Unsupported("vector(768)")?

  medicine Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@map("medicine_chunks")
}

model DiseaseMedicine {
  diseaseId  String @map("disease_id") @db.Uuid
  medicineId String @map("medicine_id") @db.Uuid

  disease  Disease  @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  medicine Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@id([diseaseId, medicineId])
  @@map("disease_medicine")
}

// ================================
// DOCTOR LEAVES (Bảng lưu Lịch Nghỉ/Báo Bận của Bác sĩ)
// ================================

model DoctorLeave {
  id       String   @id @default(uuid()) @db.Uuid
  doctorId String   @map("doctor_id") @db.Uuid
  date     DateTime @db.Date

  shift Int?

  reason String? @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  doctor Profile @relation("DoctorLeaves", fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, date, shift], name: "idx_unique_leave")
  @@index([doctorId, date])
  @@map("doctor_leaves")
}

// ================================
// APPOINTMENTS & MEDICAL RECORDS
// ================================

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Appointment {
  id        String @id @default(uuid()) @db.Uuid
  patientId String @map("patient_id") @db.Uuid
  doctorId  String @map("doctor_id") @db.Uuid

  date  DateTime @db.Date
  shift Int

  status AppointmentStatus @default(PENDING) // Ràng buộc bằng Enum
  reason String?           @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  patient Profile? @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor  Profile? @relation("DoctorAppointments", fields: [doctorId], references: [id])

  notifications Notification[]
  medicalRecord MedicalRecord?

  @@index([doctorId, date, status])
  @@index([patientId])
  @@map("appointments")
}

model MedicalRecord {
  id            String  @id @default(uuid()) @db.Uuid
  appointmentId String  @unique @map("appointment_id") @db.Uuid
  diagnosis     String  @db.Text
  prescription  String? @db.Text
  note          String? @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("medical_records")
}

// ================================
// NOTIFICATIONS
// ================================

model Notification {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  appointmentId String?  @map("appointment_id") @db.Uuid
  title         String?
  message       String?
  isRead        Boolean  @default(false) @map("is_read")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  user        Profile?     @relation(fields: [userId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([userId], name: "idx_notification_user")
  @@map("notifications")
}

// ================================
// NEWS
// ================================

model News {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  content   String
  newUrl    String?  @map("new_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("news")
}

// ================================
// AI CHAT SYSTEM
// ================================

// Khai báo Enum để phân biệt ai đang nói
enum MessageRole {
  USER // Bệnh nhân
  AI // Trợ lý MediCare
  SYSTEM // Prompt ẩn gài vào hệ thống (Không hiện lên UI)
}

model ChatSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  title     String?   @db.VarChar(255)
  topic     String?   @db.VarChar(100) // VD: "Tim mạch", "Tiêu hóa", "Da liễu"
  startedAt DateTime  @default(now()) @map("started_at") @db.Timestamptz
  endedAt   DateTime? @map("ended_at") @db.Timestamptz
  isActive  Boolean   @default(true) @map("is_active")

  user     Profile?      @relation(fields: [userId], references: [id])
  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid()) @db.Uuid
  sessionId String      @map("session_id") @db.Uuid
  role      MessageRole
  content   String      @db.Text
  metadata  Json?
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

// ================================
// USER EVENTS
// ================================ 

enum EventType {
  VIEW_DOCTOR
  BOOK_APPOINTMENT
  CANCEL_APPOINTMENT
  VIEW_DISEASE
  CHAT_AI_TOPIC
}

model UserEvent {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  eventType EventType @map("event_type")
  metadata  Json?     @default("{}") // Tất cả context (doctorId, diseaseId, shift, date, sessionId...) nằm ở đây
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventType])
  @@index([createdAt])
  @@index([metadata(ops: raw("jsonb_path_ops"))], type: Gin)
  @@map("user_events")
}

// ================================
// ETL REPORTS
// ================================

enum ReportName {
  raw_events
  top_doctors
  top_diseases
  peak_shifts
  daily_summary
  chat_topics
}

model EtlReports {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mode        String     @db.VarChar(50)
  reportName  ReportName @map("report_name")
  startDate   DateTime   @map("start_date") @db.Date
  endDate     DateTime   @map("end_date") @db.Date
  totalEvents Int?       @default(0) @map("total_events")
  reports     Json?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([reportName, startDate])
  @@map("etl_reports")
}
